# Client App Environment Variables Example
# Copy this file to .env.local for development or .env.production for production

# ── API URLs ──
# Development: use localhost
# Production: use your production domain
NEXT_PUBLIC_API_URL=https://hmcar.okigo.net
NEXT_PUBLIC_SOCKET_URL=https://hmcar.okigo.net

# ── Environment ──
NODE_ENV=production

# ── Optional: Sentry (Error Tracking) ──
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# ── Optional: Analytics ──
# NEXT_PUBLIC_GA_ID=your-google-analytics-id
